# Copy this file to .env and fill in your actual API keys
# Never commit .env — it is in .gitignore

# ── NVIDIA NIM ─────────────────────────────────────────────────────────────────
# Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# ── Tavily web search ──────────────────────────────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── Google OAuth 2.0 ───────────────────────────────────────────────────────────
# Setup guide: see docs/AUTH_SETUP.md → Google section
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── Microsoft OAuth 2.0 ────────────────────────────────────────────────────────
# Setup guide: see docs/AUTH_SETUP.md → Microsoft section
MICROSOFT_CLIENT_ID=your-microsoft-application-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret-value
