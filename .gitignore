# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-electron/
build/
# Electron compiled outputs (regenerated by build:electron / npm run dev)
main.js
main.js.map
preload.js
preload.js.map
electron/**/*.js
electron/**/*.js.map
electron/**/*.d.ts
src/pages/browser/automation/*.js
src/pages/browser/automation/*.js.map
src/pages/browser/automation/*.d.ts
# TypeScript types compiled as transitive deps of Electron build
src/types/*.js
src/studio/canvas/frames.d.ts
src/studio/canvas/icons-data.d.ts

# ── API Keys & Secrets — NEVER commit these ───────────────────────────────────
backend/.env
# search_config.json stores API keys and user preferences — keep local
backend/search_config.json

# ── User data — local only ────────────────────────────────────────────────────
data/posts.json
backend/data/
*.db

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
backend/venv/
backend/.venv/
venv/
.venv/
*.egg-info/
.eggs/
pip-log.txt

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Claude Code local session files ──────────────────────────────────────────
.claude/

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Electron packaged apps ────────────────────────────────────────────────────
out/
release/
